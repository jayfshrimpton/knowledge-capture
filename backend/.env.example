# Google Gemini API
GEMINI_API_KEY=

# Supabase — used for the database (service role key bypasses RLS) AND for
# validating Supabase email/password access tokens. Token validation uses the
# project's public JWKS (asymmetric signing keys, the Supabase default),
# derived from SUPABASE_URL: <SUPABASE_URL>/auth/v1/.well-known/jwks.json.
# No JWT secret is required for the JWKS route.
# https://supabase.com/docs/guides/getting-started/api-keys
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Microsoft Entra External ID — for JWT validation
# Azure Portal → App registrations → your app → Overview
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# Server
PORT=3001

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# Stripe — from the Stripe Dashboard
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhook secret from `stripe listen` (local) or Dashboard endpoint settings
STRIPE_WEBHOOK_SECRET=
# Price IDs for each plan (create in Stripe Dashboard > Products)
STRIPE_STARTER_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
