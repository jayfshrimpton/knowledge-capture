{
  "name": "commonplace-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Commonplace — Express + Gemini API backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm test && npm run test:integration",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:check": "tsx scripts/migrate.ts --check"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.45.0",
    "cors": "^2.8.5",
    "docx": "^9.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jszip": "^3.10.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.1.0",
    "mammoth": "^1.8.0",
    "multer": "^2.0.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.0",
    "stripe": "^22.3.0",
    "node-cron": "^3.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/pg": "^8.11.6",
    "pg": "^8.12.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.5.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/node-cron": "^3.0.0",
    "@types/pdfkit": "^0.13.4",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.9"
  }
}
