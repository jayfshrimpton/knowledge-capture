# Microsoft Entra External ID — Azure Portal → App registrations → your app → Overview
# The tenant ID and client (application) ID are both shown on the Overview page.
VITE_AZURE_TENANT_ID=your-tenant-id
VITE_AZURE_CLIENT_ID=your-client-id

# Backend API base URL
VITE_API_URL=http://localhost:3001

# Supabase — still needed for database/storage (auth is handled by Entra)
# https://supabase.com/docs/guides/getting-started/api-keys
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Stripe — publishable key for future client-side Stripe.js use
# https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=
